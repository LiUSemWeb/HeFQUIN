@prefix rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:    <http://www.w3.org/2002/07/owl#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix dc:     <http://purl.org/dc/elements/1.1/> .
@prefix fd:     <http://w3id.org/hefquin/feddesc#> .
@prefix hydra:  <http://www.w3.org/ns/hydra/core#> .

<http://w3id.org/hefquin/feddesc>
    rdf:type owl:Ontology ;
    dc:creator       "Olaf Hartig",
                     "Robin Keskisärkkä",
                     "Jonas Westman" ;
    dc:date          "2026-04-30" ;
    dc:format        "RDF" ;
    dc:identifier    <http://w3id.org/hefquin/feddesc> ;
    dc:title         "Federation Description Vocabulary for HeFQUIN"@en ;
    rdfs:label       "Federation Description Vocabulary for HeFQUIN"@en ;
    dc:description   "An RDF vocabulary for describing members of a federation to be considered for querying by the HeFQUIN engine."@en ;
    rdfs:comment     "An RDF vocabulary for describing members of a federation to be considered for querying by the HeFQUIN engine."@en .

### ===== CLASS DECLARATIONS =====

fd:FederationMember a owl:Class ;
    rdfs:label "Federation Member"@en ;
    rdfs:comment "An entity that is part of the federation and provides access to data via a specific interface. Every federation member must have an fd:serviceURI property and an fd:interface property. This class is a superclass of any kind of federation member and should not be used directly within federation descriptions. Concrete types of federation members, to be used in federation descriptions, are captured by the subclasses of this class."@en .

fd:RDFBasedFederationMember a owl:Class ;
    rdfs:subClassOf fd:FederationMember ;
    rdfs:label "RDF-based Federation Member"@en ;
    rdfs:comment "A federation member whose interface exposes RDF data. Every such federation member must have the two properties that are expected for any kind of federation member (i.e., fd:serviceURI and fd:interface), where the fd:interface may be either an fd:FixedEndpointInterface with the fd:supportedProtocol being fd:SPARQLProtocol or an fd:FragmentInterface. Additionally, an RDF-based federation member may have an fd:vocabularyMappingsFile property."@en .

fd:WrappedFederationMember a owl:Class ;
    rdfs:subClassOf fd:FederationMember ;
    rdfs:label "Wrapped Federation Member"@en ;
    rdfs:comment "A federation member that provides access to non-RDF data, for which it is associated with a wrapper that defines and RDF view of the data of that federation member. In addition to the properties that are expected for any kind of federation member (i.e., fd:serviceURI and fd:interface), such a wrapped federation member must have an fd:wrapper property."@en .

fd:Interface a owl:Class ;
    rdfs:label "Interface"@en ;
    rdfs:comment "An interface is a means to issue data retrieval requests to a federation member. This class is a superclass of any kind of interface and should not be used directly within federation descriptions. Concrete types of interfaces, to be used in federation descriptions, are captured by the subclasses of this class."@en .

fd:FixedEndpointInterface a owl:Class ;
    rdfs:subClassOf fd:Interface ;
    rdfs:label "Fixed Endpoint Interface"@en ;
    rdfs:comment "An interface that can be accessed via a single, fixed endpoint address. Every such interface must have an fd:endpointAddress property and an fd:supportedProtocol property. The value for the fd:supportedProtocol property is expected to be one of the following: fd:SPARQLProtocol, fd:BoltProtocol, fd:GraphQLProtocol, or fd:GenericWebAPIProtocol."@en .

fd:TemplateBasedInterface a owl:Class ;
    rdfs:subClassOf fd:Interface ;
    rdfs:label "Template-based Interface"@en ;
    rdfs:comment "An interface that can be accessed via request URIs that can be created based on a URI template. Every such interface must have an fd:uriTemplate property and an fd:supportedProtocol property. For the time being, the value for the fd:supportedProtocol property is expected to be fd:GenericWebAPIProtocol."@en .

fd:FragmentInterface a owl:Class ;
    rdfs:subClassOf fd:Interface ;
    rdfs:label "Fragment Interface"@en ;
    rdfs:comment "An interface that can be accessed via URIs that denote fragments (i.e., specific subsets) of the dataset of the corresponding federation member, where the way in which these URIs are formed is communicated in responses to requests to such an interface. Every such interface must have an fd:exampleFragmentAddress property and an fd:supportedProtocol property. The value for the fd:supportedProtocol property is expected to be either fd:TPFProtocol or fd:brTPFProtocol."@en .

fd:Wrapper a owl:Class ;
    rdfs:label "Wrapper"@en ;
    rdfs:comment "A wrapper provides a mapping for data of federation members that do not support RDF and SPARQL natively. For the time being, every such wrapper must have either an fd:rmlTriplesMaps property or an fd:mappingConfiguration property. In particular, for wrappers associated with a federation member whose interface has fd:GenericWebAPIProtocol as the fd:supportedProtocol, the wrapper must have an fd:rmlTriplesMaps property; and for wrappers associated with a federation member whose interface has fd:BoltProtocol or fd:GraphQLProtocol as the fd:supportedProtocol, the wrapper must have an fd:mappingConfiguration property."@en .

fd:DataRetrievalProtocol a owl:Class ;
    rdfs:label "Data Retrieval Protocol"@en ;
    rdfs:comment "Instances of this class represent the different protocols to be used when interacting with the interface of a federation member."@en .

fd:Authentication a owl:Class ;
    rdfs:label "Authentication"@en ;
    rdfs:comment "Authentication information associated with an interface. This class is a superclass of any kind of authentication mechanism and should not be used directly within federation descriptions. Concrete authentication mechanisms, to be used in federation descriptions, are captured by the subclasses of this class."@en .

fd:HttpHeaderAuthentication a owl:Class ;
    rdfs:subClassOf fd:Authentication ;
    rdfs:label "HTTP Header Authentication"@en ;
    rdfs:comment "Authentication based on one or more HTTP request headers. Every such authentication description must specify the HTTP header(s) to be attached to requests sent to the associated interface. This mechanism can be used for authentication schemes such as Bearer tokens, API keys or other header-based authentication methods."@en .

fd:HttpBasicAuthentication a owl:Class ;
    rdfs:subClassOf fd:Authentication ;
    rdfs:label "HTTP Basic Authentication"@en ;
    rdfs:comment "Authentication using the HTTP Basic authentication scheme. Every such authentication description must specify a username and a password. The corresponding Authorization header is constructed automatically by the implementation."@en .

fd:HttpHeader a owl:Class ;
    rdfs:label "HTTP Header"@en ;
    rdfs:comment "A single HTTP header consisting of a name and a value."@en .


### ===== PROPERTY DECLARATIONS =====

fd:serviceURI a owl:DatatypeProperty ;
    rdfs:domain fd:FederationMember ;
    rdfs:range  xsd:anyURI ;
    rdfs:label "service URI"@en ;
    rdfs:comment "The URI via which the federation member is identified in a SERVICE clause."@en .

fd:interface a owl:ObjectProperty ;
    rdfs:domain fd:FederationMember ;
    rdfs:range  fd:Interface ;
    rdfs:label "interface"@en ;
    rdfs:comment "The interface for accessing the federation member."@en .

fd:supportedProtocol a owl:ObjectProperty ;
    rdfs:domain fd:Interface ;
    rdfs:range  fd:DataRetrievalProtocol ;
    rdfs:label "supported protocol"@en ;
    rdfs:comment "The data retrieval protocol supported by the interface."@en .

fd:endpointAddress a owl:DatatypeProperty ;
    rdfs:domain fd:FixedEndpointInterface ;
    rdfs:range  xsd:anyURI ;
    rdfs:label "endpoint address"@en ;
    rdfs:comment "The network address (URI) of the endpoint of the federation member."@en .

fd:uriTemplate a owl:ObjectProperty ;
    rdfs:domain fd:TemplateBasedInterface ;
    rdfs:range  hydra:IriTemplate ;
    rdfs:label "URI template"@en ;
    rdfs:comment "The template for creating URIs that can be used for issuing requests to the interface. The template is captured as a hydra:IriTemplate, which must have a hydra:template property and, if the template contains variable parts, there must also be a hydra:mapping property for each of these variable parts."@en .

fd:paramType a owl:ObjectProperty ;
    rdfs:domain hydra:IriTemplateMapping ;
    rdfs:range  rdfs:Resource ;
    rdfs:label "type of template parameter"@en ;
    rdfs:comment "The type of values to be used for a variable part of a URI template. This type is expected to be specified as a datatype URI (e.g., xsd:string, xsd:float). This property is optional; i.e., not every IriTemplateMapping needs to have it. If a IriTemplateMapping has this property, the datatype specified via this property is enforced when creating request URIs from the corresponding IriTemplate; i.e., the IriTemplate will be instantiated only for parameter values that have the specified datatype."@en .

fd:exampleFragmentAddress a owl:DatatypeProperty ;
    rdfs:domain fd:FragmentInterface ;
    rdfs:range  xsd:anyURI ;
    rdfs:label "example fragment address"@en ;
    rdfs:comment "An example URI of a fragment for the fragment interface."@en .

fd:vocabularyMappingsFile a owl:DatatypeProperty ;
    rdfs:domain fd:RDFBasedFederationMember ;
    rdfs:range  xsd:string ;
    rdfs:label "vocabulary mappings file"@en ;
    rdfs:comment "Path to a file with RDF mappings to align different vocabularies."@en .

fd:wrapper a owl:ObjectProperty ;
    rdfs:domain fd:WrappedFederationMember ;
    rdfs:range  fd:Wrapper ;
    rdfs:label "wrapper"@en ;
    rdfs:comment "The wrapper of a wrapped federation member."@en .

fd:rmlTriplesMaps a owl:ObjectProperty ;
    rdfs:domain fd:Wrapper ;
    rdfs:range  rdf:List ;
    rdfs:label "RML triples maps"@en ;
    rdfs:comment "List of RML triples maps that define the mapping for a wrapper. The elements of such a list are expected to be of type rml:TriplesMap. ATTENTION: for the time being, these triples maps must all be normalized as per the definition in Section 5 of the paper titled 'An Algebraic Foundation for Knowledge Graph Construction'."@en .

fd:mappingConfiguration a owl:ObjectProperty ;
    rdfs:domain fd:Wrapper ;
    rdfs:range  rdfs:Resource ;
    rdfs:label "mapping configuration"@en ;
    rdfs:comment "Mapping configuration for translating non-RDF data models to RDF (e.g., GraphQL, PG)."@en .

fd:authentication a owl:ObjectProperty ;
    rdfs:domain fd:Interface ;
    rdfs:range fd:Authentication ;
    rdfs:label "authentication"@en ;
    rdfs:comment "Associates an interface with authentication information required to access it. If absent, the interface is assumed to be publicly accessible."@en .

fd:headers a owl:ObjectProperty ;
    rdfs:domain fd:HttpHeaderAuthentication ;
    rdfs:range rdf:List ;
    rdfs:label "HTTP headers"@en ;
    rdfs:comment "A collection of HTTP headers that are attached to requests sent to the associated interface. Each element of the list is expected to be an instance of fd:HttpHeader."@en .


### ===== INSTANCES =====

fd:SPARQLProtocol a fd:DataRetrievalProtocol ;
    rdfs:label "SPARQL protocol"@en ;
    rdfs:comment "The protocol to be used for SPARQL endpoints."@en .

fd:BoltProtocol a fd:DataRetrievalProtocol ;
    rdfs:label "Bolt protocol"@en ;
    rdfs:comment "The protocol to be used when interacting with a Neo4j server."@en .

fd:GraphQLProtocol a fd:DataRetrievalProtocol ;
    rdfs:label "GraphQL protocol"@en ;
    rdfs:comment "The protocol to be used when interacting with a GraphQL server."@en .

fd:TPFProtocol a fd:DataRetrievalProtocol ;
    rdfs:label "TPF protocol"@en ;
    rdfs:comment "The protocol to be used when interacting with a TPF server."@en .

fd:brTPFProtocol a fd:DataRetrievalProtocol ;
    rdfs:label "brTPF protocol"@en ;
    rdfs:comment "The protocol to be used when interacting with a brTPF server."@en .

fd:GenericWebAPIProtocol a fd:DataRetrievalProtocol ;
    rdfs:label "Generic Web API protocol"@en ;
    rdfs:comment "The protocol to be used when interacting with a generic Web API."@en .

fd:headerName a owl:DatatypeProperty ;
    rdfs:domain fd:HttpHeader ;
    rdfs:range xsd:string ;
    rdfs:label "header name"@en ;
    rdfs:comment "The name of an HTTP header."@en .

fd:headerValue a owl:DatatypeProperty ;
    rdfs:domain fd:HttpHeader ;
    rdfs:range xsd:string ;
    rdfs:label "header value"@en ;
    rdfs:comment "The value of an HTTP header."@en .

fd:username a owl:DatatypeProperty ;
    rdfs:domain fd:HttpBasicAuthentication ;
    rdfs:range xsd:string ;
    rdfs:label "username"@en ;
    rdfs:comment "The username used for HTTP Basic authentication."@en .

fd:password a owl:DatatypeProperty ;
    rdfs:domain fd:HttpBasicAuthentication ;
    rdfs:range xsd:string ;
    rdfs:label "password"@en ;
    rdfs:comment "The password used for HTTP Basic authentication."@en .