PREFIX rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX xsd:    <http://www.w3.org/2001/XMLSchema#>
PREFIX fd:     <http://w3id.org/hefquin/feddesc#>
PREFIX rml:    <http://w3id.org/rml/>
PREFIX cdt:	   <http://w3id.org/awslabs/neptune/SPARQL-CDTs/>
PREFIX ex:     <http://example.org/>
PREFIX hydra:  <http://www.w3.org/ns/hydra/core#>


ex:dbpediaSPARQL
      fd:serviceURI <http://dbpedia.org/sparql> ;
      fd:interface [ a                  fd:SPARQLEndpointInterface ;
                     fd:endpointAddress <http://dbpedia.org/sparql> ] .

ex:dbpediaTPF
      fd:serviceURI <http://fragments.dbpedia.org/2016-04/en> ;
      fd:interface [ a                         fd:TPFInterface ;
                     fd:exampleFragmentAddress <http://fragments.dbpedia.org/2016-04/en> ] .

ex:wikidataSPARQL
      fd:serviceURI <https://query.wikidata.org/sparql> ;
      fd:interface [ a                  fd:SPARQLEndpointInterface ;
                     fd:endpointAddress <https://query.wikidata.org/sparql> ] .

ex:dbpediaSPARQLWithVocabMappings
      fd:serviceURI <http://example.org/DBpediaWrapper> ;
      fd:interface [ a                  fd:SPARQLEndpointInterface ;
                     fd:endpointAddress <http://dbpedia.org/sparql> ] ;
      fd:vocabularyMappingsFile "examples/ExampleVocabMappingDBpedia.ttl" .

ex:wikidataSPARQLWithVocabMappings
      fd:serviceURI <http://example.org/WikidataWrapper> ;
      fd:interface [ a                  fd:SPARQLEndpointInterface ;
                     fd:endpointAddress <https://query.wikidata.org/sparql> ];
      fd:vocabularyMappingsFile "examples/ExampleVocabMappingWikidata.ttl" .

ex:europaSPARQL
      fd:serviceURI <https://data.europa.eu/sparql> ;
      fd:interface [ a                  fd:SPARQLEndpointInterface ;
                     fd:endpointAddress <https://data.europa.eu/sparql> ] .

ex:openMeteo
      fd:serviceURI <http://example.org/OpenMeteoWrapper> ;
      fd:interface _:openMeteoRestEndpoint ;
      fd:wrapper _:openMeteoWrapper .

_:openMeteoRestEndpoint a fd:RESTInterface ;
      fd:iriTemplate [
            hydra:template "https://api.open-meteo.com/v1/forecast{?latitude,longitude,current,hourly}" ;
            hydra:mapping [ hydra:variable "latitude" ;
                            hydra:required true ;
                            fd:paramType xsd:float
                          ] ,
                          [ hydra:variable "longitude" ;
                            hydra:required true ;
                            fd:paramType xsd:float
                          ] ,
                          [ hydra:variable "current" ;
                            fd:paramType xsd:string
                          ] ,
                          [ hydra:variable "hourly" ;
                            fd:paramType xsd:string
                          ]
          ] .                   

ex:openMeteo2
      fd:serviceURI <http://example.org/OpenMeteoWrapperWithFixedParams> ;
      fd:interface [ a fd:RESTInterface ;
            fd:iriTemplate [
                  hydra:template "https://api.open-meteo.com/v1/forecast?latitude=52.52&longitude=13.41&current=temperature_2m,wind_speed_10m" ;
            ] 
      ] ;
      fd:wrapper _:openMeteoWrapper .

_:openMeteoWrapper
      fd:rmlTriplesMaps (
            _:openMeteoTM1
            _:openMeteoTM2
            _:openMeteoTM3
            _:openMeteoTM4
      ) .

_:openMeteoTM1
      rml:logicalSource [ rml:source _:openMeteoRestEndpoint ;
                          rml:referenceFormulation rml:JSONPath ;
                          rml:iterator "$.current" ] ;
      rml:subjectMap [ rml:termType rml:BlankNode ;
                       rml:reference "time" ];
      rml:predicateObjectMap [ rml:predicateMap [ rml:constant ex:temperature ] ;
                               rml:objectMap [ rml:reference "temperature_2m" ; rml:datatype xsd:double ] ] .

_:openMeteoTM2
      rml:logicalSource [ rml:source _:openMeteoRestEndpoint ;
                          rml:referenceFormulation rml:JSONPath ;
                          rml:iterator "$.current" ] ;
      rml:subjectMap [ rml:termType rml:BlankNode ;
                       rml:reference "time" ];
      rml:predicateObjectMap [ rml:predicateMap [ rml:constant ex:windSpeed ] ;
                               rml:objectMap [ rml:reference "wind_speed_10m" ; rml:datatype xsd:double ] ] .

_:openMeteoTM3
      rml:logicalSource [ rml:source _:openMeteoRestEndpoint ;
                          rml:referenceFormulation rml:JSONPath ;
                          rml:iterator "$" ] ;
      rml:subjectMap [ rml:termType rml:BlankNode ;
                       rml:reference "current.time" ];
      rml:predicateObjectMap [ rml:predicateMap [ rml:constant ex:current ] ;
                               rml:objectMap [ rml:reference "current" ; rml:datatype cdt:Map ] ] .

_:openMeteoTM4
      rml:logicalSource [ rml:source _:openMeteoRestEndpoint ;
                          rml:referenceFormulation rml:JSONPath ;
                          rml:iterator "$" ] ;
      rml:subjectMap [ rml:termType rml:BlankNode ;
                       rml:reference "hourly_units.time" ];
      rml:predicateObjectMap [ rml:predicateMap [ rml:constant ex:hourly_temperature ] ;
                               rml:objectMap [ rml:reference "hourly.temperature_2m" ; rml:datatype cdt:List ] ] .


ex:covid19API
      fd:serviceURI <http://example.org/Covid19APIWrapper> ;
      fd:interface _:covid19APIEndpoint ;
      fd:wrapper [ fd:rmlTriplesMaps ( _:covid19TM_totalCases
                                       _:covid19TM_todayCases
                                       _:covid19TM_totalDeaths
                                       _:covid19TM_todayDeaths
                                       _:covid19TM_totalRecovered
                                       _:covid19TM_updated )
                 ] .

_:covid19APIEndpoint a fd:RESTInterface ;
      fd:iriTemplate [ hydra:template "https://disease.sh/v3/covid-19/countries/{country}" ;
                       hydra:mapping [ hydra:variable "country" ;
                                       hydra:required true ;
                                       fd:paramType xsd:string ]
                     ] .

_:covid19TM_totalCases
    rml:logicalSource [ rml:source _:covid19APIEndpoint ;
                        rml:referenceFormulation rml:JSONPath ;
                        rml:iterator "$" ] ;
    rml:subjectMap [ rml:termType rml:BlankNode ; rml:reference "country" ] ;
    rml:predicateObjectMap [
        rml:predicateMap [ rml:constant ex:totalCases ] ;
        rml:objectMap [ rml:reference "cases" ; rml:datatype xsd:integer ]
    ] .

_:covid19TM_todayCases
    rml:logicalSource [ rml:source _:covid19APIEndpoint ;
                        rml:referenceFormulation rml:JSONPath ;
                        rml:iterator "$" ] ;
    rml:subjectMap [ rml:termType rml:BlankNode ; rml:reference "country" ] ;
    rml:predicateObjectMap [
        rml:predicateMap [ rml:constant ex:todayCases ] ;
        rml:objectMap [ rml:reference "todayCases" ; rml:datatype xsd:integer ]
    ] .

_:covid19TM_totalDeaths
    rml:logicalSource [ rml:source _:covid19APIEndpoint ;
                        rml:referenceFormulation rml:JSONPath ;
                        rml:iterator "$" ] ;
    rml:subjectMap [ rml:termType rml:BlankNode ; rml:reference "country" ] ;
    rml:predicateObjectMap [
        rml:predicateMap [ rml:constant ex:totalDeaths ] ;
        rml:objectMap [ rml:reference "deaths" ; rml:datatype xsd:integer ]
    ] .

_:covid19TM_todayDeaths
    rml:logicalSource [ rml:source _:covid19APIEndpoint ;
                        rml:referenceFormulation rml:JSONPath ;
                        rml:iterator "$" ] ;
    rml:subjectMap [ rml:termType rml:BlankNode ; rml:reference "country" ] ;
    rml:predicateObjectMap [
        rml:predicateMap [ rml:constant ex:todayDeaths ] ;
        rml:objectMap [ rml:reference "todayDeaths" ; rml:datatype xsd:integer ]
    ] .

_:covid19TM_totalRecovered
    rml:logicalSource [ rml:source _:covid19APIEndpoint ;
                        rml:referenceFormulation rml:JSONPath ;
                        rml:iterator "$" ] ;
    rml:subjectMap [ rml:termType rml:BlankNode ; rml:reference "country" ] ;
    rml:predicateObjectMap [
        rml:predicateMap [ rml:constant ex:totalRecovered ] ;
        rml:objectMap [ rml:reference "recovered" ; rml:datatype xsd:integer ]
    ] .

_:covid19TM_updated
    rml:logicalSource [ rml:source _:covid19APIEndpoint ;
                        rml:referenceFormulation rml:JSONPath ;
                        rml:iterator "$" ] ;
    rml:subjectMap [ rml:termType rml:BlankNode ; rml:reference "country" ] ;
    rml:predicateObjectMap [
        rml:predicateMap [ rml:constant ex:updated ] ;
        rml:objectMap [ rml:reference "updated" ; rml:datatype xsd:long ]
    ] .


# ============================================================
# Open Library Search API (JSON REST)
# ============================================================

ex:openLibraryBooks
      fd:serviceURI <http://example.org/OpenLibraryWrapper> ;
      fd:interface _:booksEndpoint ;
      fd:wrapper _:booksWrapper .

_:booksEndpoint a fd:RESTInterface ;
      fd:iriTemplate [
            hydra:template "https://openlibrary.org/search.json{?author,limit}" ;
            hydra:mapping
                  [ hydra:variable "author" ; hydra:required true ; fd:paramType xsd:string ],
                  [ hydra:variable "limit" ; hydra:required false ; fd:paramType xsd:integer ]
          ] .

_:booksWrapper
      fd:rmlTriplesMaps ( _:bookTitleTM _:bookAuthorTM _:bookPublishedTM _:bookEditionsTM ) .

_:bookTitleTM
      rml:logicalSource [ rml:source _:booksEndpoint ;
                          rml:referenceFormulation rml:JSONPath ;
                          rml:iterator "$.docs[*]" ] ;
      rml:subjectMap [ rml:template "http://example.org/book{key}" ; rml:class ex:Book ];
      rml:predicateObjectMap [ rml:predicateMap [ rml:constant ex:title ] ;
                               rml:objectMap [ rml:reference "title" ] ] .

_:bookAuthorTM
      rml:logicalSource [ rml:source _:booksEndpoint ;
                          rml:referenceFormulation rml:JSONPath ;
                          rml:iterator "$.docs[*]" ] ;
      rml:subjectMap [ rml:template "http://example.org/book{key}" ];
      rml:predicateObjectMap [ rml:predicateMap [ rml:constant ex:author ] ;
                               rml:objectMap [ rml:reference "author_name[0]" ] ] .

_:bookPublishedTM
      rml:logicalSource [ rml:source _:booksEndpoint ;
                          rml:referenceFormulation rml:JSONPath ;
                          rml:iterator "$.docs[*]" ] ;
      rml:subjectMap [ rml:template "http://example.org/book{key}" ];
      rml:predicateObjectMap [ rml:predicateMap [ rml:constant ex:firstPublished ] ;
                               rml:objectMap [ rml:reference "first_publish_year" ; rml:datatype xsd:integer ] ] .

_:bookEditionsTM
      rml:logicalSource [ rml:source _:booksEndpoint ;
                          rml:referenceFormulation rml:JSONPath ;
                          rml:iterator "$.docs[*]" ] ;
      rml:subjectMap [ rml:template "http://example.org/book{key}" ];
      rml:predicateObjectMap [ rml:predicateMap [ rml:constant ex:editionCount ] ;
                               rml:objectMap [ rml:reference "edition_count" ; rml:datatype xsd:integer ] ] .


# ============================================================
# REST Countries v2 API - Simpler country information structure
# Returns country data with currency codes in simpler array format
# ============================================================

ex:countriesAPI
      fd:serviceURI <http://example.org/CountriesAPIWrapper> ;
      fd:interface _:countriesEndpoint ;
      fd:wrapper _:countriesWrapper .

_:countriesEndpoint a fd:RESTInterface ;
      fd:iriTemplate [
            hydra:template "https://restcountries.com/v2/name/{country}" ;
            hydra:mapping
                  [ hydra:variable "country" ; hydra:required true ; fd:paramType xsd:string ]
          ] .

_:countriesWrapper
      fd:rmlTriplesMaps ( _:countryNameTM _:countryCapitalTM _:countryPopulationTM _:countryCurrencyTM _:countryRegionTM ) .

_:countryNameTM
      rml:logicalSource [ rml:source _:countriesEndpoint ;
                          rml:referenceFormulation rml:JSONPath ;
                          rml:iterator "$[*]" ] ;
      rml:subjectMap [ rml:template "http://example.org/country/{alpha3Code}" ; rml:class ex:Country ];
      rml:predicateObjectMap [ rml:predicateMap [ rml:constant ex:countryName ] ;
                               rml:objectMap [ rml:reference "name" ] ] .

_:countryCapitalTM
      rml:logicalSource [ rml:source _:countriesEndpoint ;
                          rml:referenceFormulation rml:JSONPath ;
                          rml:iterator "$[*]" ] ;
      rml:subjectMap [ rml:template "http://example.org/country/{alpha3Code}" ];
      rml:predicateObjectMap [ rml:predicateMap [ rml:constant ex:capital ] ;
                               rml:objectMap [ rml:reference "capital" ] ] .

_:countryPopulationTM
      rml:logicalSource [ rml:source _:countriesEndpoint ;
                          rml:referenceFormulation rml:JSONPath ;
                          rml:iterator "$[*]" ] ;
      rml:subjectMap [ rml:template "http://example.org/country/{alpha3Code}" ];
      rml:predicateObjectMap [ rml:predicateMap [ rml:constant ex:population ] ;
                               rml:objectMap [ rml:reference "population" ; rml:datatype xsd:integer ] ] .

_:countryCurrencyTM
      rml:logicalSource [ rml:source _:countriesEndpoint ;
                          rml:referenceFormulation rml:JSONPath ;
                          rml:iterator "$[*]" ] ;
      rml:subjectMap [ rml:template "http://example.org/country/{alpha3Code}" ];
      rml:predicateObjectMap [ rml:predicateMap [ rml:constant ex:currencyCode ] ;
                               rml:objectMap [ rml:reference "currencies[0].code" ] ] .

_:countryRegionTM
      rml:logicalSource [ rml:source _:countriesEndpoint ;
                          rml:referenceFormulation rml:JSONPath ;
                          rml:iterator "$[*]" ] ;
      rml:subjectMap [ rml:template "http://example.org/country/{alpha3Code}" ];
      rml:predicateObjectMap [ rml:predicateMap [ rml:constant ex:region ] ;
                               rml:objectMap [ rml:reference "region" ] ] .


# ============================================================
# Exchange Rates API - Get currency exchange rates
# ============================================================

ex:exchangeRatesAPI
      fd:serviceURI <http://example.org/ExchangeRatesAPIWrapper> ;
      fd:interface _:exchangeEndpoint ;
      fd:wrapper _:exchangeWrapper .

_:exchangeEndpoint a fd:RESTInterface ;
      fd:iriTemplate [
            hydra:template "https://api.exchangerate-api.com/v4/latest/{base}" ;
            hydra:mapping
                  [ hydra:variable "base" ; hydra:required true ; fd:paramType xsd:string ]
          ] .

_:exchangeWrapper
      fd:rmlTriplesMaps ( _:exchangeRateEURTM _:exchangeDateTM ) .

_:exchangeRateEURTM
      rml:logicalSource [ rml:source _:exchangeEndpoint ;
                          rml:referenceFormulation rml:JSONPath ;
                          rml:iterator "$" ] ;
      rml:subjectMap [ rml:template "http://example.org/exchange/{base}" ];
      rml:predicateObjectMap [ rml:predicateMap [ rml:constant ex:eurRate ] ;
                               rml:objectMap [ rml:reference "rates.EUR" ; rml:datatype xsd:double ] ] .

_:exchangeDateTM
      rml:logicalSource [ rml:source _:exchangeEndpoint ;
                          rml:referenceFormulation rml:JSONPath ;
                          rml:iterator "$" ] ;
      rml:subjectMap [ rml:template "http://example.org/exchange/{base}" ];
      rml:predicateObjectMap [ rml:predicateMap [ rml:constant ex:date ] ;
                               rml:objectMap [ rml:reference "date" ] ] .



