      {
        "@language": "en",
        "@value": "Specifies the federation access manager to be used in a configuration of the HeFQUIN engine. Every such configuration has only one federation access manager."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "http://w3id.org/hefquin/engineconf#HeFQUINEngineConfiguration"
