      }
    ]
  },
  {
    "@id": "http://w3id.org/hefquin/engineconf#InstantiationBasedConstructorArgument",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "Every instance of this class represents a Java object that is obtained by instantiating a Java class and that is meant to be passed to a constructor in order to instantiate another Java class. In addition to the 'javaClassName' property and the (optional) 'constructorArguments' property, every instance of this class must have exactly one 'argumentTypeName' property. The value of this property is either the same as the value of the 'javaClassName' property or it is the name of a superclass or an interface of the class mentioned by the 'javaClassName' property."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "Instantiation-Based Constructor Argument"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "http://w3id.org/hefquin/engineconf#ConstructorArgument"
      },
      {
        "@id": "http://w3id.org/hefquin/engineconf#InstantiableJavaClass"
      }
    ]
  },
  {
    "@id": "http://w3id.org/hefquin/engineconf#argumentTypeName",
    "@type": [
      "http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "Specifies the full name of a Java class or of a Java interface."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "http://w3id.org/hefquin/engineconf#InstantiationBasedConstructorArgument"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "name of Java class or a Java interface"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://www.w3.org/2000/10/XMLSchema#string"
      }
    ]
  },
  {
    "@id": "http://w3id.org/hefquin/engineconf#SourcePlanner",
