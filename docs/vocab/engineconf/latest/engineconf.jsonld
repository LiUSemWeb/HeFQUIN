      }
    ]
  },
  {
    "@id": "http://w3id.org/hefquin/engineconf#queryProcessor",
    "@type": [
      "http://www.w3.org/1999/02/22-rdf-syntax-ns#Property"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "Specifies the query processor to be used in a configuration of the HeFQUIN engine. Every such configuration has only one query processor."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#domain": [
      {
        "@id": "http://w3id.org/hefquin/engineconf#HeFQUINEngineConfiguration"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "query processor"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#range": [
      {
        "@id": "http://w3id.org/hefquin/engineconf#QueryProcessor"
      }
    ]
  },
  {
