PREFIX rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:   <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd:    <http://www.w3.org/2001/XMLSchema#>
PREFIX owl:    <http://www.w3.org/2002/07/owl#>
PREFIX dbo:    <http://dbpedia.org/ontology/>

# This query demonstrates a join between data from two SPARQL endpoints: the
# SPARQL endpoint of the DBpedia Knowledge Graph and the SPARQL endpoint of
# the Wikidata Knowledge Graph.
# Notice that, after deciding the join order and deciding to use the bind-join
# algorithm, HeFQUIN pushes the FILTER into the request to the DBpedia endpoint.

SELECT * WHERE {
	SERVICE <http://dbpedia.org/sparql> {
		<http://dbpedia.org/resource/Berlin> dbo:country ?c .
		?c owl:sameAs ?cc
	}

	FILTER ( CONTAINS(STR(?cc), "wikidata" ) )

	SERVICE <https://query.wikidata.org/sparql> {
		?cc rdfs:label ?o
	}
}
